{
  "compilerOptions": {
    "target": "ES2020",
    "types": [],
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "declarationDir": ".",
    "outDir": "dist",
    "strict": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "importHelpers": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
